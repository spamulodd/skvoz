#!/bin/sh
. /usr/lib/rvpn/common.sh
. /usr/lib/rvpn/dns.sh
. /usr/lib/rvpn/nft.sh
. /usr/lib/rvpn/singbox.sh
. /usr/lib/rvpn/zapret.sh
. /usr/lib/rvpn/zapret-strat.sh
. /usr/lib/rvpn/zapret-sync.sh
. /usr/lib/rvpn/zapret-test.sh
. /usr/lib/rvpn/health.sh
. /usr/lib/rvpn/cidr-sync.sh
. /usr/lib/rvpn/sub.sh
. /usr/lib/rvpn/node-pool.sh
. /usr/lib/rvpn/adblock.sh
. /usr/lib/rvpn/nfqws-fetch.sh
. /usr/lib/rvpn/update.sh
. /usr/lib/rvpn/selftest.sh
. /usr/lib/rvpn/ui-api.sh

cmd=${1:-status}

svc() {
	rvpn_with_lock /etc/init.d/rvpn "$@"
}

case "$cmd" in
status)
	health_status_json
	echo "---"
	echo "zapret_enabled=$(uci -q get rvpn.main.zapret_enabled)"
	echo "vpn_enabled=$(uci -q get rvpn.main.vpn_enabled)"
	echo "disable_quic=$(uci -q get rvpn.main.disable_quic)"
	adblock_status_line
	echo "dns_mode=$(cat /tmp/rvpn/dns.applied 2>/dev/null || echo off)"
	if [ -f /tmp/rvpn/nfqws.pid ] && kill -0 "$(cat /tmp/rvpn/nfqws.pid 2>/dev/null)" 2>/dev/null; then
		echo "nfqws: running pid=$(cat /tmp/rvpn/nfqws.pid)"
	elif pgrep -af '^/opt/rvpn/nfqws' >/dev/null 2>&1; then
		pgrep -af '^/opt/rvpn/nfqws'
	else
		echo "nfqws: not running"
	fi
	pgrep -af '/tmp/rvpn/sing-box.json' 2>/dev/null || echo "sing-box: not running"
	nft list tables 2>/dev/null | grep rvpn || echo "nft: no rvpn tables"
	;;
start)
	RVPN_CLEAR_HOLD=1 svc start
	;;
stop)
	svc stop
	;;
restart)
	RVPN_CLEAR_HOLD=1 svc restart
	;;
failsafe)
	mode=${2:-hard}
	case "$mode" in soft|hard) ;; *) mode=hard ;; esac
	# Prefer short lock; always restore DNS
	if ! rvpn_with_lock_timeout 8 /bin/sh -c "
		. /usr/lib/rvpn/ui-api.sh
		ui_failsafe_run '$mode'
	"; then
		. /usr/lib/rvpn/ui-api.sh
		ui_failsafe_run "$mode"
	fi
	;;
enable-zapret)
	uci set rvpn.main.zapret_enabled='1'
	uci commit rvpn
	svc restart
	;;
disable-zapret)
	uci set rvpn.main.zapret_enabled='0'
	uci commit rvpn
	svc restart
	;;
enable-vpn)
	uci set rvpn.main.vpn_enabled='1'
	uci commit rvpn
	svc restart
	# After VPN: Flowseal lists + nfqws + optional autotune
	(
		sleep 3
		zapret_after_vpn_ready
	) >/dev/null 2>&1 &
	;;
disable-vpn)
	uci set rvpn.main.vpn_enabled='0'
	uci commit rvpn
	svc restart
	;;
enable-adblock)
	uci set rvpn.main.adblock_enabled='1'
	uci commit rvpn
	adblock_apply || { echo FAIL; exit 1; }
	health_cron_install 2>/dev/null || true
	echo OK
	;;
disable-adblock)
	uci set rvpn.main.adblock_enabled='0'
	uci commit rvpn
	adblock_apply && echo OK || { echo FAIL; exit 1; }
	;;
adblock-update)
	adblock_update && echo OK || { echo FAIL; exit 1; }
	;;

adblock-status)
	adblock_status_line
	;;
gen-config)
	sb_generate && echo "OK $RVPN_SB_JSON" || echo FAIL
	;;
add-domain)
	[ -n "$2" ] || { echo "Usage: rvpnctl add-domain example.com"; exit 1; }
	vpn_user_add "$2" || exit 1
	sb_reload_domains && echo "OK added $(normalize_domain "$2")" || echo "saved (reload failed)"
	;;
del-domain)
	[ -n "$2" ] || { echo "Usage: rvpnctl del-domain example.com"; exit 1; }
	vpn_user_del "$2"
	sb_reload_domains && echo "OK removed $(normalize_domain "$2")" || echo "removed (reload failed)"
	;;
list-domains)
	echo "# shipped (vpn-domains.txt)"
	list_domains "$RVPN_RULES/vpn-domains.txt"
	echo "# user (vpn-user.txt)"
	list_domains "$RVPN_USER_DOMAINS"
	;;
ui-secret)
	ensure_ui_secret
	;;
log)
	tail -n "${2:-80}" "$RVPN_LOG" 2>/dev/null
	;;
load)
	# Take a sample now, then show recent hourly history
	health_load_sample
	echo "# ts load_x100 mem_avail_kb mem_total_kb lan_clients wan_rx wan_tx vpn zap"
	tail -n "${2:-48}" "$RVPN_LOAD_LOG" 2>/dev/null || echo "(no samples yet)"
	;;
sync-cidr)
	cidr_sync_run && echo OK || { echo FAIL; exit 1; }
	;;
sub-refresh)
	# Refresh one subscription id, or all enabled
	if [ -n "$2" ]; then
		sub_refresh "$2" && echo OK || { echo FAIL; exit 1; }
	else
		sub_refresh_all && echo OK || { echo FAIL; exit 1; }
	fi
	;;
sub-import)
	# Alias: refresh + print last_count (does not restart VPN)
	sid=$2
	[ -n "$sid" ] || { echo "Usage: rvpnctl sub-import <subscription_id>"; exit 1; }
	n=$(sub_refresh "$sid") || { echo FAIL; exit 1; }
	echo "OK imported=$n"
	;;
nodes-probe)
	pool_probe_all || { echo FAIL; exit 1; }
	echo "# delay_ms tag id"
	cat "$RVPN_RUN/pool/delays.tsv" 2>/dev/null
	;;
pool-optimize)
	# Probe + enable best keep / disable dead; does not auto-restart
	pool_run || { echo FAIL; exit 1; }
	echo "HINT: rvpnctl restart  # apply enabled set"
	;;
zapret-strategies)
	zapret_strat_list
	echo "current=$(zapret_strat_id)"
	;;
zapret-strategy)
	# rvpnctl zapret-strategy [id]
	if [ -n "$2" ]; then
		zapret_strat_set "$2" || { echo FAIL; exit 1; }
		if [ "$(uci_get zapret_enabled)" = "1" ]; then
			zapret_start && nft_apply_zapret || { echo FAIL; exit 1; }
		fi
		echo "OK strategy=$2"
	else
		zapret_strat_json
	fi
	;;
zapret-sync)
	zapret_sync_run && echo OK || { echo FAIL; cat "$RVPN_RUN/zapret_sync.warn" 2>/dev/null; exit 1; }
	;;
zapret-test)
	# Test one strategy (default: current)
	zapret_test_one "${2:-}" || { echo FAIL; exit 1; }
	;;
zapret-autotune)
	zapret_test_autotune || { echo FAIL; exit 1; }
	;;
nfqws-fetch)
	nfqws_fetch_run && echo OK || { echo FAIL; exit 1; }
	;;
update-check)
	update_check_json
	;;
update-status)
	update_status_json
	;;
update)
	update_run || { echo FAIL; exit 1; }
	if [ -f "$RVPN_RUN/update.restart" ]; then
		rm -f "$RVPN_RUN/update.restart"
		RVPN_CLEAR_HOLD=1 /etc/init.d/rvpn restart || true
	fi
	;;
selftest)
	selftest_run
	;;
setup-done)
	ui_setup_done_set
	;;
wifi-qr)
	ui_wifi_qr_json
	;;
*)
	echo "Usage: rvpnctl status|start|stop|restart|failsafe [soft|hard]|enable-*|disable-*|…|zapret-*|nfqws-fetch|update-check|update|selftest|setup-done|wifi-qr|pool-optimize|sub-*"
	exit 1
	;;
esac
