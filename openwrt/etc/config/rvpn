config rvpn 'main'
	option zapret_enabled '0'
	option vpn_enabled '0'
	option dns_listen '127.0.0.42'
	option dns_port '53'
	option fakeip_inet4_range '198.18.0.0/15'
	option tproxy_port '12345'
	option tproxy_mark '0x1'
	option route_table '100'
	option clash_api '127.0.0.1:9090'
	option clash_secret ''
	option ui_secret 'CHANGE_ME'
	option disable_quic '1'
	option urltest_url 'https://www.gstatic.com/generate_204'
	option urltest_interval '2m'
	option urltest_tolerance '100'
	option pool_keep '6'
	option pool_min_alive '2'
	option pool_probe_timeout_ms '5000'
	option zapret_qnum '200'
	option zapret_strategy 'general_alt11'
	option setup_done '0'
	option adblock_enabled '0'
	option adblock_list_url 'https://small.oisd.nl/'
	option adblock_update_hours '24'
	option log_level 'warn'

config node 'vps_hy2'
	option enabled '1'
	option tag 'vps-fi-hy2'
	option type 'hysteria2'
	option server 'YOUR_VPS_IP'
	option port '433'
	option password 'YOUR_HY2_PASSWORD'
	option sni 'bing.com'
	option insecure '0'

# Clash Meta / URI subscription (disabled until URL is set).
# Set URL (do not commit live tokens):
#   uci set rvpn.sub1.url='https://YOUR_PANEL/TOKEN'
#   uci set rvpn.sub1.enabled='1'
#   uci commit rvpn
#   rvpnctl sub-import sub1
#   rvpnctl enable-vpn   # or restart if already on
# Optional: rvpnctl pool-optimize && rvpnctl restart
config subscription 'sub1'
	option enabled '0'
	option url ''
	option ua 'clash.meta'
	option refresh_hours '12'
	option max_nodes '24'
	option prefer 'vless-reality,hysteria2,trojan,vless-ws,vless-grpc,vless,ss'
	option skip_keywords 'expire,剩余,流量,官网,套餐'
